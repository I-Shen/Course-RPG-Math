# ================================================================
# PIXEL MATH RPG - Environment Variables Template
# ================================================================
# CARA PAKAI:
# 1. Copy file ini: cp .env.example .env
# 2. Isi nilai yang diperlukan di file .env
# 3. JANGAN pernah commit file .env ke GitHub!
# ================================================================

# ── Gemini API Key (untuk AI Tutor) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gemini Model (opsional, default: gemini-3.5-flash) ──────────
# Jika model default sibuk (error 503), Anda bisa ganti ke gemini-2.5-flash
# Pilihan model: gemini-3.5-flash, gemini-2.5-flash, gemini-2.0-flash, dll.
GEMINI_MODEL=gemini-3.5-flash

# ── Ollama Model (fallback jika Gemini error / kuota habis) ─────
# Pastikan Ollama sudah diinstall: https://ollama.com/
# Jalankan model: ollama pull phi3
# Pilihan model: phi3, llama3, mistral, gemma2, dll.
OLLAMA_MODEL=phi3
